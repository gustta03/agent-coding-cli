# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agent_boilerplate

# CORS (comma-separated origins or * for all)
CORS_ORIGIN=*

# AI - Groq
GROQ_API_KEY=your_groq_api_key_here

# Modelos VERIFICADOS disponíveis (Março 2026):
# 1. llama-3.3-70b-versatile (RECOMENDADO - 70B, 131k context, tool calling)
# 2. llama-3.1-8b-instant (Rápido - 8B, 131k context)
# 3. groq/compound (Groq próprio - 131k context, 8k output)
# 4. groq/compound-mini (Menor, 131k context)
# 5. qwen/qwen3-32b (Alternativa - 131k context)

# DESCONTINUADOS (não use):
# - llama-3.1-70b-versatile
# - mixtral-8x7b-32768
# - gemma2-9b-it

GROQ_MODEL=llama-3.3-70b-versatile
